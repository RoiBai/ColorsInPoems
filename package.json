{
  "name": "colors-in-chinese-poems",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "data:download": "node scripts/download-corpus.js",
    "data:normalize": "node scripts/normalize-corpus.js",
    "data:extract": "node scripts/extract-colors.js && node scripts/extract-imagery.js && node scripts/extract-emotions.js",
    "data:build": "node scripts/build-stats.js",
    "data:biography": "node scripts/build-poet-biography.js",
    "data:assign-time": "node scripts/assign-poem-time.js",
    "data:trajectory": "node scripts/build-poet-color-trajectory.js",
    "data:all": "npm run data:download && npm run data:normalize && npm run data:extract && npm run data:build && npm run data:biography && npm run data:assign-time && npm run data:trajectory",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "framer-motion": "^12.23.26",
    "opencc-js": "^1.3.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "6.0.11"
  }
}
